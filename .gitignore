# === Python (Caches e Artefatos) ===
__pycache__/
.pytest_cache/
.ruff_cache/
.coverage
htmlcov/
*.py[cod]
*$py.class
*.log

# === Ambiente Virtual e Segredos ===
.venv/
venv/
env/
.env
build/
dist/
*.egg-info/

# === Saídas do Projeto (DDD Output) ===
