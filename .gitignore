output/

# === Configurações e Estado ===
# Mantendo o padrão de permitir arquivos de configuração base
!config/settings.json

# Pasta de dados temporários ou cache de análise
data/

# === Cache de Ferramentas ===
.cache/
.pre-commit/

# === IDEs e Editores ===
.vscode/*
!.vscode/settings.json
.idea/
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo

# === Ferramentas de IA (Caches Locais) ===
.gemini/
.antigravity/
.agent/
.agents/