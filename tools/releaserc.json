{
  "branches": [
    "main"
  ],
  "plugins": [
    [
      "@semantic-release/commit-analyzer",
      {
        "preset": "conventionalcommits",
        "releaseRules": [
          {
            "breaking": true,
            "release": "major"
          },
          {
            "release": "patch",
            "type": "build"
          },
          {
            "release": "patch",
            "type": "chore"
          },
          {
            "release": "patch",
            "type": "ci"
          },
          {
            "release": "patch",
            "type": "docs"
          },
          {
            "release": "minor",
            "type": "feat"
          },
          {
            "release": "patch",
            "type": "fix"
          },
          {
            "release": "patch",
            "type": "perf"
          },
          {
            "release": "patch",
            "type": "qa"
          },
          {
            "release": "patch",
            "type": "refactor"
          },
          {
            "release": "patch",
            "type": "revert"
          },
          {
            "release": "patch",
            "type": "style"
          },
          {
            "release": "patch",
            "type": "test"
          }
        ]
      }
    ],
    [
      "@semantic-release/release-notes-generator",
      {
        "parserOpts": {
          "noteKeywords": [
            "BREAKING CHANGE",
            "BREAKING CHANGES"
          ]
        },
        "preset": "conventionalcommits",
        "presetConfig": {
          "types": [
            {
              "hidden": false,
              "section": "Breaking Changes",
              "type": "breaking"
            },
            {
              "hidden": false,
              "section": "Build",
              "type": "build"
            },
            {
              "hidden": false,
              "section": "Chore",
              "type": "chore"
            },
            {
              "hidden": false,
              "section": "CI/CD",
              "type": "ci"
            },
            {
              "hidden": false,
              "section": "Documentacao",
              "type": "docs"
            },
            {
              "hidden": false,
              "section": "Nova Funcionalidade",
              "type": "feat"
            },
            {
              "hidden": false,
              "section": "Bug Fix",
              "type": "fix"
            },
            {
              "hidden": false,
              "section": "Performance",
              "type": "perf"
            },
            {
              "hidden": false,
              "section": "Qualidade",
              "type": "qa"
            },
            {
              "hidden": false,
              "section": "Refatoracao",
              "type": "refactor"
            },
            {
              "hidden": false,
              "section": "Reversao",
              "type": "revert"
            },
            {
              "hidden": false,
              "section": "Estilo",
              "type": "style"
            },
            {
              "hidden": false,
              "section": "Testes",
              "type": "test"
            }
          ]
        }
      }
    ],
    [
      "@semantic-release/changelog",
      {
        "changelogFile": "CHANGELOG.md"
      }
    ],
    [
      "@semantic-release/git",
      {
        "assets": [
          "CHANGELOG.md"
        ],
        "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
      }
    ],
    "@semantic-release/github"
  ]
}
